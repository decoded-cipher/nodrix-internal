# --- Common ---
# Hostname of your worker — no scheme, no path.
NODRIX_HOST=your.workers.dev

# Project connection token. One token per project — shared by every node and
# the controller. Create it on the project's Variables page ("Create token").
# Used for telemetry POST and the control WS.
NODRIX_TOKEN=

# How often sensors POST telemetry (ms).
INTERVAL_MS=5000
