---
import { getCollection } from 'astro:content';
import Site from '../../layouts/Site.astro';
import Waves from '../../components/Waves.astro';
import CtaBand from '../../components/CtaBand.astro';
import { breadcrumb, itemList, jsonLdGraph, readingTime } from '../../lib/seo';

const CATEGORY_LABEL: Record<string, string> = {
  hardware: 'Hardware',
  project: 'Project',
  comparison: 'Comparison',
  concept: 'Concept',
};
const CATEGORY_ORDER = ['hardware', 'project', 'comparison', 'concept'];
const boardLabel = (b: string) => (b === 'Raspberry Pi Pico W' ? 'Pico W' : b);

const all = await getCollection('guides');
const byDate = (a: { data: { datePublished: Date } }, b: { data: { datePublished: Date } }) =>
  b.data.datePublished.getTime() - a.data.datePublished.getTime();

const published = all.filter((g) => !g.data.draft).sort(byDate);
const upcoming = all.filter((g) => g.data.draft).sort(byDate);

// Filter facets, derived from the guides themselves so they never drift.
const categories = CATEGORY_ORDER.filter((c) => published.some((g) => g.data.category === c));
const boards = [...new Set(published.map((g) => g.data.board).filter(Boolean))].sort() as string[];

const site = Astro.site!;
const jsonLd = jsonLdGraph(
  itemList(
    'nodrix guides',
    'Hands-on guides for connecting hardware to the cloud, building dashboards, and automating IoT.',
    published.map((g) => ({ name: g.data.title, description: g.data.description })),
  ),
  breadcrumb(site, [
    { name: 'Home', path: '/' },
    { name: 'Guides', path: '/guides' },
  ]),
);
---

<Site
  title="Guides — connect hardware to the cloud | nodrix"
  description="Hands-on, no-fluff guides for IoT makers: connect an ESP32 to the cloud over HTTPS, receive commands back, build dashboards, and squeeze months of battery life out of a sensor."
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <section class="hero-glow relative overflow-hidden border-b border-neutral-200/70">
    <Waves />
    <div class="relative mx-auto max-w-4xl px-5 py-16 sm:px-6 sm:py-24">
      <span class="text-sm font-semibold text-accent-600">Guides</span>
      <h1 class="mt-2 text-balance text-4xl font-extrabold tracking-tight text-neutral-900 sm:text-5xl">
        Ship the project, not the plumbing.
      </h1>
      <p class="mt-5 max-w-2xl text-pretty text-base leading-relaxed text-neutral-600 sm:text-lg">
        Practical, tested walk-throughs for getting hardware talking to the cloud — real Arduino
        code, the bits other tutorials skip (like getting commands back to the device), and the
        battery tricks that make a sensor last months.
      </p>
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto max-w-5xl px-5 py-16 sm:px-6 sm:py-20">
      <!-- Controls -->
      <div class="border-b border-neutral-100 pb-8">
        <div class="relative mx-auto max-w-xl">
          <svg class="pointer-events-none absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-neutral-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          <input
            id="guide-search"
            type="search"
            autocomplete="off"
            placeholder="Search guides…"
            aria-label="Search guides"
            class="w-full rounded-xl border border-neutral-200 bg-white py-3 pl-11 pr-4 text-sm text-neutral-900 shadow-sm transition-shadow placeholder:text-neutral-400 focus:border-accent-300 focus:shadow-md focus:outline-none focus:ring-2 focus:ring-accent-500/20"
          />
        </div>

        <div class="mt-5 flex flex-wrap items-center justify-center gap-2" role="group" aria-label="Filter guides">
          <button type="button" class="g-chip" data-kind="all" aria-pressed="true">All</button>
          {categories.map((c) => (
            <button type="button" class="g-chip" data-kind="category" data-val={c} aria-pressed="false">{CATEGORY_LABEL[c]}</button>
          ))}
          {boards.map((b) => (
            <button type="button" class="g-chip" data-kind="board" data-val={b} aria-pressed="false">{boardLabel(b)}</button>
          ))}
        </div>
      </div>

      <!-- Grid -->
      <div id="guide-grid" class="mt-8 grid gap-5 md:grid-cols-2">
        {published.map((g) => (
          <a
            data-guide
            data-category={g.data.category}
            data-board={g.data.board ?? ''}
            data-text={`${g.data.title} ${g.data.description} ${CATEGORY_LABEL[g.data.category]} ${g.data.board ?? ''}`.toLowerCase()}
            href={`/guides/${g.id}`}
            class="group flex flex-col rounded-2xl border border-neutral-200 bg-white p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-accent-200 hover:shadow-lg hover:shadow-accent-500/5"
          >
            <div class="flex items-center gap-2">
              <span class="rounded-full bg-accent-50 px-2.5 py-0.5 text-[11px] font-semibold text-accent-700">{CATEGORY_LABEL[g.data.category]}</span>
              {g.data.board && <span class="rounded-full bg-neutral-100 px-2.5 py-0.5 text-[11px] font-semibold text-neutral-600">{g.data.board}</span>}
              <span class="ml-auto text-[11px] text-neutral-400">{readingTime(g.body ?? '')}</span>
            </div>
            <h2 class="mt-3 text-lg font-bold leading-snug tracking-tight text-neutral-900 transition-colors group-hover:text-accent-700">{g.data.title}</h2>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-neutral-600 line-clamp-3">{g.data.description}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-accent-600">
              Read the guide <span class="transition-transform group-hover:translate-x-0.5" aria-hidden="true">→</span>
            </span>
          </a>
        ))}
      </div>

      <!-- Empty state -->
      <div id="guide-empty" class="hidden py-16 text-center">
        <p class="text-sm text-neutral-500">No guides match your search.</p>
        <button type="button" id="guide-reset" class="mt-3 text-sm font-semibold text-accent-600 hover:text-accent-700">Clear filters</button>
      </div>

      <!-- Footer: result count (left) + pagination (right) -->
      <div id="guide-footer" class="mt-10 hidden flex flex-col items-center gap-4 border-t border-neutral-100 pt-6 sm:flex-row sm:justify-between">
        <p id="guide-count" class="text-sm text-neutral-500" aria-live="polite"></p>
        <nav id="guide-pager" class="g-pager" aria-label="Guides pagination"></nav>
      </div>

      {upcoming.length > 0 && (
        <div class="mt-14 border-t border-neutral-100 pt-10">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-neutral-400">Coming soon</h2>
          <div class="mt-4 grid gap-5 md:grid-cols-2">
            {upcoming.map((g) => (
              <a
                href={`/guides/${g.id}`}
                class="group flex flex-col rounded-2xl border border-dashed border-neutral-200 bg-neutral-50/60 p-6 transition-colors hover:bg-neutral-50"
              >
                <div class="flex items-center gap-2">
                  <span class="rounded-full bg-neutral-100 px-2.5 py-0.5 text-[11px] font-semibold text-neutral-500">{CATEGORY_LABEL[g.data.category]}</span>
                  {g.data.board && <span class="rounded-full bg-neutral-100 px-2.5 py-0.5 text-[11px] font-semibold text-neutral-500">{g.data.board}</span>}
                  <span class="ml-auto rounded-full bg-amber-100 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-amber-700">Draft</span>
                </div>
                <h3 class="mt-3 text-base font-semibold leading-snug text-neutral-700">{g.data.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-neutral-500">{g.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <CtaBand />

  <style is:global>
    .g-chip {
      display: inline-flex;
      align-items: center;
      border-radius: 9999px;
      padding: 0.375rem 0.875rem;
      font-size: 0.8125rem;
      font-weight: 600;
      line-height: 1;
      border: 1px solid #e5e5e5;
      background: #fff;
      color: #525252;
      cursor: pointer;
      transition: color 0.15s, border-color 0.15s, background-color 0.15s;
    }
    .g-chip:hover {
      border-color: #d4d4d4;
      color: #171717;
    }
    .g-chip[aria-pressed='true'] {
      background: var(--color-accent-600);
      border-color: var(--color-accent-600);
      color: #fff;
    }
    .g-pager {
      display: inline-flex;
      align-items: center;
      border: 1px solid #e5e5e5;
      border-radius: 0.75rem;
      overflow: hidden;
      background: #fff;
    }
    .g-pager-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 2.25rem;
      min-width: 2.25rem;
      padding: 0 0.75rem;
      border: 0;
      border-left: 1px solid #ececec;
      background: #fff;
      color: #525252;
      font-size: 0.875rem;
      font-weight: 600;
      font-variant-numeric: tabular-nums;
      cursor: pointer;
      transition: color 0.15s, background-color 0.15s;
    }
    .g-pager-btn:first-child {
      border-left: 0;
    }
    .g-pager-btn:hover:not(:disabled) {
      background: #f5f5f5;
      color: #171717;
    }
    .g-pager-btn:disabled {
      color: #cfcfcf;
      cursor: not-allowed;
    }
    .g-pager-btn[aria-current='page'] {
      background: var(--color-accent-600);
      color: #fff;
    }
    .g-pager-btn svg {
      width: 1rem;
      height: 1rem;
    }
  </style>

  <script is:inline>
    (function () {
      var PER_PAGE = 6;
      var grid = document.getElementById('guide-grid');
      if (!grid) return;
      var cards = Array.prototype.slice.call(grid.querySelectorAll('[data-guide]'));
      var search = document.getElementById('guide-search');
      var chips = Array.prototype.slice.call(document.querySelectorAll('[data-kind]'));
      var pager = document.getElementById('guide-pager');
      var footer = document.getElementById('guide-footer');
      var countEl = document.getElementById('guide-count');
      var emptyEl = document.getElementById('guide-empty');
      var resetBtn = document.getElementById('guide-reset');

      // One active filter at a time: {kind:'all'|'category'|'board', val}.
      var state = { q: '', filter: { kind: 'all', val: null }, page: 1 };

      function chipFor(kind, val) {
        for (var i = 0; i < chips.length; i++) {
          if (chips[i].getAttribute('data-kind') === kind && chips[i].getAttribute('data-val') === val) return chips[i];
        }
        return null;
      }

      var params = new URLSearchParams(location.search);
      if (params.get('q')) state.q = params.get('q');
      if (params.get('topic') && chipFor('category', params.get('topic'))) state.filter = { kind: 'category', val: params.get('topic') };
      else if (params.get('board') && chipFor('board', params.get('board'))) state.filter = { kind: 'board', val: params.get('board') };
      if (params.get('page')) state.page = Math.max(1, parseInt(params.get('page'), 10) || 1);

      function pressChips() {
        chips.forEach(function (c) {
          var on = c.getAttribute('data-kind') === state.filter.kind &&
            (state.filter.kind === 'all' || c.getAttribute('data-val') === state.filter.val);
          c.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
      }

      if (search) search.value = state.q;
      pressChips();

      function matches(card) {
        var f = state.filter;
        if (f.kind === 'category' && card.getAttribute('data-category') !== f.val) return false;
        if (f.kind === 'board' && card.getAttribute('data-board') !== f.val) return false;
        if (state.q && card.getAttribute('data-text').indexOf(state.q.toLowerCase()) === -1) return false;
        return true;
      }

      function syncUrl() {
        var p = new URLSearchParams();
        if (state.q) p.set('q', state.q);
        if (state.filter.kind === 'category') p.set('topic', state.filter.val);
        else if (state.filter.kind === 'board') p.set('board', state.filter.val);
        if (state.page > 1) p.set('page', String(state.page));
        var qs = p.toString();
        history.replaceState(null, '', qs ? location.pathname + '?' + qs : location.pathname);
      }

      var CHEVRON_L = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>';
      var CHEVRON_R = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>';

      function pagerBtn(opts) {
        var b = document.createElement('button');
        b.type = 'button';
        b.className = 'g-pager-btn';
        if (opts.html) b.innerHTML = opts.html; else b.textContent = opts.text;
        if (opts.disabled) b.disabled = true;
        if (opts.current) b.setAttribute('aria-current', 'page');
        if (opts.ariaLabel) b.setAttribute('aria-label', opts.ariaLabel);
        b.addEventListener('click', function () {
          if (opts.disabled) return;
          state.page = opts.page;
          render();
          grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
        return b;
      }

      function renderPager(pages) {
        pager.innerHTML = '';
        if (pages <= 1) { pager.style.display = 'none'; return; }
        pager.style.display = '';
        pager.appendChild(pagerBtn({ html: CHEVRON_L, page: state.page - 1, disabled: state.page === 1, ariaLabel: 'Previous page' }));
        for (var i = 1; i <= pages; i++) {
          pager.appendChild(pagerBtn({ text: String(i), page: i, current: i === state.page, ariaLabel: 'Page ' + i }));
        }
        pager.appendChild(pagerBtn({ html: CHEVRON_R, page: state.page + 1, disabled: state.page === pages, ariaLabel: 'Next page' }));
      }

      function render() {
        var filtered = cards.filter(matches);
        var total = filtered.length;
        var pages = Math.max(1, Math.ceil(total / PER_PAGE));
        if (state.page > pages) state.page = pages;
        var start = (state.page - 1) * PER_PAGE;
        var end = start + PER_PAGE;

        cards.forEach(function (c) { c.classList.add('hidden'); });
        filtered.slice(start, end).forEach(function (c) { c.classList.remove('hidden'); });

        if (total === 0) {
          grid.classList.add('hidden');
          footer.classList.add('hidden');
          emptyEl.classList.remove('hidden');
          countEl.textContent = '';
        } else {
          grid.classList.remove('hidden');
          footer.classList.remove('hidden');
          emptyEl.classList.add('hidden');
          countEl.textContent =
            total <= PER_PAGE
              ? total + (total === 1 ? ' guide' : ' guides')
              : (start + 1) + '–' + Math.min(end, total) + ' of ' + total + ' guides';
        }

        renderPager(pages);
        syncUrl();
      }

      function reset() {
        state.q = '';
        state.filter = { kind: 'all', val: null };
        state.page = 1;
        if (search) search.value = '';
        pressChips();
        render();
      }

      if (search) search.addEventListener('input', function () { state.q = search.value.trim(); state.page = 1; render(); });
      chips.forEach(function (c) {
        c.addEventListener('click', function () {
          var kind = c.getAttribute('data-kind');
          state.filter = kind === 'all' ? { kind: 'all', val: null } : { kind: kind, val: c.getAttribute('data-val') };
          state.page = 1;
          pressChips();
          render();
        });
      });
      if (resetBtn) resetBtn.addEventListener('click', reset);

      render();
    })();
  </script>
</Site>
