---
// Tracking redirect: this page registers as a pageview in Cloudflare Web
// Analytics (so /go/deploy count = Deploy-button clicks), then forwards to
// Cloudflare's deploy URL. A short delay lets the auto-injected beacon fire.
const repoUrl = 'https://github.com/decoded-cipher/nodrix';
const deployUrl = `https://deploy.workers.cloudflare.com/?url=${encodeURIComponent(repoUrl)}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta http-equiv="refresh" content={`3;url=${deployUrl}`} />
    <title>Redirecting to Cloudflare…</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        min-height: 100svh;
        display: grid;
        place-items: center;
        padding: 24px;
        text-align: center;
        background: #0a0a0b;
        color: #fafafa;
        font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      /* centered accent glow */
      body::before {
        content: '';
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 680px;
        height: 680px;
        background: radial-gradient(closest-side, rgba(255, 106, 69, 0.16), transparent 70%);
        pointer-events: none;
      }
      .wrap { position: relative; display: flex; flex-direction: column; align-items: center; }
      .logo { height: 26px; width: auto; opacity: 0.95; }

      /* on-brand radar ping */
      .radar { position: relative; width: 132px; height: 132px; margin: 40px 0 32px; }
      .radar .ping {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        border: 1.5px solid rgba(255, 106, 69, 0.5);
        animation: ping 2.4s cubic-bezier(0, 0, 0.2, 1) infinite;
      }
      .radar .ping:nth-child(2) { animation-delay: 0.8s; }
      .radar .ping:nth-child(3) { animation-delay: 1.6s; }
      .radar .core {
        position: absolute;
        inset: 0;
        margin: auto;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: #ff6a45;
        box-shadow: 0 0 28px 5px rgba(255, 106, 69, 0.55);
      }
      @keyframes ping {
        0% { transform: scale(0.18); opacity: 0.85; }
        80%, 100% { transform: scale(1); opacity: 0; }
      }

      h1 { font-size: 22px; font-weight: 700; letter-spacing: -0.01em; }
      p { margin-top: 10px; font-size: 15px; color: #a3a3a3; }
      .hint { margin-top: 22px; font-size: 13px; color: #737373; }
      a { color: #ff6a45; text-decoration: none; font-weight: 600; }
      a:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <img class="logo" src="/white_logo.png" alt="nodrix" width="160" height="46" />

      <div class="radar" aria-hidden="true">
        <span class="ping"></span>
        <span class="ping"></span>
        <span class="ping"></span>
        <span class="core"></span>
      </div>

      <h1>Taking you to Cloudflare…</h1>
      <p>Opening the one-click deploy for nodrix in your account.</p>
      <p class="hint">Not redirected? <a href={deployUrl}>Continue &rarr;</a></p>
    </div>

    <script is:inline define:vars={{ deployUrl }}>
      setTimeout(function () {
        location.replace(deployUrl);
      }, 2000);
    </script>
  </body>
</html>
