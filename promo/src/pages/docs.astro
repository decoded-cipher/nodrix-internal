  </style>

  <script>
    // Scrollspy: highlight the "On this page" link for the section in view.
    const list = document.querySelector('[data-toc]');
    if (list) {
      const links = Array.from(list.querySelectorAll('a[href^="#"]'));
      const ids = links.map((a) => (a.getAttribute('href') || '').slice(1));
      const sections = ids
        .map((id) => document.getElementById(id))
        .filter((el): el is HTMLElement => el !== null);

      let current = '';
      const setActive = (id: string) => {
        if (id === current) return;
        current = id;
        for (const a of links) {
          const on = a.getAttribute('href') === '#' + id;
          a.classList.toggle('border-accent-500', on);
          a.classList.toggle('text-neutral-900', on);
          a.classList.toggle('font-medium', on);
          a.classList.toggle('border-transparent', !on);
          a.classList.toggle('text-neutral-600', !on);
        }
      };

      const visible = new Set();
      const observer = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) visible.add(e.target.id);
            else visible.delete(e.target.id);
          }
          const topmost = ids.find((id) => visible.has(id));
          if (topmost) setActive(topmost);
        },
        { rootMargin: '-120px 0px -66% 0px', threshold: 0 }
      );

      sections.forEach((s) => observer.observe(s));
    }
  </script>
