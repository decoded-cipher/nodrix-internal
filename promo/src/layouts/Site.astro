---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  /** Path or absolute URL to the social share image. */
  image?: string;
  /** Open Graph type, e.g. "website" or "article". */
  type?: string;
  /** When true, ask crawlers not to index this page. */
  noindex?: boolean;
}

const { title, description, image = '/og.png', type = 'website', noindex = false } = Astro.props;

// Analytics (prod-only, env-gated): Microsoft Clarity + Google Analytics 4.
const clarityId = import.meta.env.PUBLIC_CLARITY_ID;
const gaId = import.meta.env.PUBLIC_GA_ID;

const repoUrl = 'https://github.com/decoded-cipher/nodrix';
const sdkRepoUrl = 'https://github.com/decoded-cipher/nodrix-sdk';
const productHuntUrl = 'https://www.producthunt.com/products/nodrix';

const nav = [
  { href: '/#features', label: 'Features' },
  { href: '/guides', label: 'Guides' },
  { href: '/docs', label: 'Docs' },
  { href: '/widgets', label: 'Widgets' },
  { href: '/blog', label: 'Blog' },
];
const desc = description ?? 'Open-source IoT platform that deploys to your own Cloudflare account. Hardware POSTs over HTTPS, realtime drag-and-drop dashboards, automations, and a clean read API.';

const siteName = 'nodrix';
const imageAlt = 'nodrix — your own IoT cloud, on Cloudflare';

// Everything below derives from `site` in astro.config.mjs — change the
// domain there and canonical / OG / JSON-LD all follow.
const site = Astro.site!;
// `file` build → pathname is /docs.html; normalize to the served form (/docs, /).
const cleanPath = Astro.url.pathname.replace(/\.html$/, '').replace(/\/?index$/, '') || '/';
const canonical = new URL(cleanPath, site).href;
const ogImage = new URL(image, site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': new URL('#org', site).href,
      name: siteName,
      url: site.href,
      logo: new URL('/icon-512.png', site).href,
      email: 'hello@nodrix.live',
      sameAs: [repoUrl, productHuntUrl],
    },
    {
      '@type': 'WebSite',
      '@id': new URL('#website', site).href,
      name: siteName,
      url: site.href,
      description: desc,
      publisher: { '@id': new URL('#org', site).href },
    },
    {
      '@type': 'SoftwareApplication',
      name: siteName,
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Cloudflare Workers',
      description: desc,
      url: site.href,
      softwareVersion: '1.0',
      isAccessibleForFree: true,
      license: 'https://opensource.org/licenses/MIT',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      sameAs: [repoUrl],
    },
  ],
};
---

<!doctype html>
<html lang="en" class="h-full scroll-pt-20">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="nodrix guides" href={new URL('rss.xml', site).href} />
    <meta
      name="robots"
      content={noindex
        ? 'noindex, nofollow'
        : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}
    />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <meta name="theme-color" content="#ff6a45" />

    <!-- Structured data (JSON-LD) -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Self-hosted fonts: preload the body/headline face for LCP. -->
    <link rel="preload" href="/fonts/plus-jakarta-sans.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Page-specific head tags (per-page JSON-LD, etc.) -->
    <slot name="head" />

    <!-- Microsoft Clarity -->
    {import.meta.env.PROD && clarityId && (
      <script is:inline define:vars={{ clarityId }}>
        (function (c, l, a, r, i, t, y) {
          c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments) };
          t = l.createElement(r); t.async = 1; t.src = "https://www.clarity.ms/tag/" + i;
          y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
        })(window, document, "clarity", "script", clarityId);
      </script>
    )}

    <!-- Google Analytics 4 -->
    {import.meta.env.PROD && gaId && (
      <Fragment>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </Fragment>
    )}

    <!-- Analytics events → GA4 + Clarity. No-op if neither is loaded (dev).
         Fire declaratively with data-track="event_name" on any element. -->
    <script is:inline>
      window.track = function (name, params) {
        try { if (window.gtag) window.gtag('event', name, params || {}); } catch (e) {}
        try { if (window.clarity) window.clarity('event', name); } catch (e) {}
      };
      document.addEventListener('click', function (e) {
        const el = e.target.closest && e.target.closest('[data-track]');
        if (el) window.track(el.getAttribute('data-track'));
      });
    </script>
  </head>
  <body class="min-h-full bg-white text-neutral-900 antialiased font-sans">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-neutral-900 focus:px-4 focus:py-2 focus:text-sm focus:text-white"
    >Skip to content</a>

    <header class="sticky top-0 z-40 border-b border-neutral-200/70 bg-white/80 backdrop-blur-md">
      <nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-3.5 sm:px-6">
        <a href="/" class="flex shrink-0 items-center" aria-label="nodrix home">
          <picture>
            <source srcset="/dark_logo.webp" type="image/webp" />
            <img src="/dark_logo.png" alt="nodrix" class="h-6 w-auto sm:h-7" width="120" height="35" />
          </picture>
        </a>

        <div class="hidden items-center gap-7 text-sm font-medium text-neutral-600 md:flex">
          {nav.map((item) => (
            <a href={item.href} class="transition-colors hover:text-neutral-900">{item.label}</a>
          ))}
        </div>

        <div class="hidden items-center gap-2 md:flex">
          <a
            href={repoUrl}
            class="inline-flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-neutral-600 transition-colors hover:bg-neutral-100 hover:text-neutral-900"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.4.5 0 5.9 0 12.5c0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 24 12.5C24 5.9 18.6.5 12 .5Z"/></svg>
            GitHub
          </a>
          <a
            href="/go/deploy"
            target="_blank"
            rel="noopener noreferrer"
            data-track="deploy_click"
            class="inline-flex items-center gap-2 rounded-lg bg-accent-500 px-3 py-2 text-sm font-semibold text-white shadow-sm shadow-accent-500/25 transition-all hover:bg-accent-600 hover:shadow-md hover:shadow-accent-500/30 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-500"
          >
            Deploy
          </a>
        </div>

        <button
          id="menu-toggle"
          type="button"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="inline-flex items-center justify-center rounded-lg p-2 text-neutral-700 hover:bg-neutral-100 md:hidden"
        >
          <svg id="icon-open" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
          <svg id="icon-close" class="hidden h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
      </nav>

      <div id="mobile-menu" class="absolute inset-x-0 top-full hidden border-t border-neutral-200/70 bg-white shadow-lg md:hidden">
        <div class="space-y-1 px-5 py-4">
          {nav.map((item) => (
            <a href={item.href} class="block rounded-lg px-3 py-2.5 text-base font-medium text-neutral-700 hover:bg-neutral-100">{item.label}</a>
          ))}
          <a href={repoUrl} class="block rounded-lg px-3 py-2.5 text-base font-medium text-neutral-700 hover:bg-neutral-100">GitHub</a>
          <a
            href="/go/deploy"
            target="_blank"
            rel="noopener noreferrer"
            data-track="deploy_click"
            class="mt-1 block w-full rounded-lg bg-accent-500 px-3 py-2.5 text-center text-base font-semibold text-white transition-colors hover:bg-accent-600"
          >
            Deploy
          </a>
        </div>
      </div>
    </header>

    <main id="main"><slot /></main>

    <footer class="relative overflow-hidden border-t border-neutral-200 bg-neutral-50">
      <div class="mx-auto max-w-6xl px-5 sm:px-6">
        <div class="flex flex-col gap-12 py-14 md:flex-row md:items-start md:justify-between">
          <div class="max-w-sm">
            <picture>
              <source srcset="/dark_logo.webp" type="image/webp" />
              <img src="/dark_logo.png" alt="nodrix" class="h-7 w-auto" width="140" height="41" />
            </picture>
            <p class="mt-4 text-sm leading-relaxed text-neutral-500">
              Your own IoT cloud — open source, single-tenant, and running entirely on your Cloudflare account.
            </p>
            <a
              href={`${productHuntUrl}?embed=true&utm_source=badge-featured&utm_medium=badge&utm_campaign=badge-nodrix`}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 inline-block"
            >
              <img
                src={'https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1157071&theme=light'}
                alt="Nodrix — Featured on Product Hunt"
                width="250"
                height="54"
                loading="lazy"
              />
            </a>
          </div>

          <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 sm:gap-12 lg:gap-16">
            <div>
              <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-400">Product</h3>
              <ul class="mt-4 space-y-2.5 text-sm text-neutral-600">
                <li><a href="/#features" class="transition-colors hover:text-accent-600">Features</a></li>
                <li><a href="/widgets" class="transition-colors hover:text-accent-600">Widgets</a></li>
                <li><a href="/roadmap" class="transition-colors hover:text-accent-600">Roadmap</a></li>
                <li><a href="/changelog" class="transition-colors hover:text-accent-600">Changelog</a></li>
              </ul>
            </div>
            <div>
              <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-400">Developers</h3>
              <ul class="mt-4 space-y-2.5 text-sm text-neutral-600">
                <li><a href="/guides" class="transition-colors hover:text-accent-600">Guides</a></li>
                <li><a href="/blog" class="transition-colors hover:text-accent-600">Blog</a></li>
                <li><a href="/docs" class="transition-colors hover:text-accent-600">Docs</a></li>
                <li><a href={sdkRepoUrl} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-accent-600">Arduino library</a></li>
              </ul>
            </div>
            <div>
              <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-400">Project</h3>
              <ul class="mt-4 space-y-2.5 text-sm text-neutral-600">
                <li><a href={repoUrl} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-accent-600">GitHub</a></li>
                <li><a href={`${repoUrl}/blob/master/README.md`} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-accent-600">README</a></li>
                <li><a href={`${repoUrl}/issues/new`} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-accent-600">Report an issue</a></li>
                <li><a href="mailto:hello@nodrix.live" class="transition-colors hover:text-accent-600">Contact</a></li>
              </ul>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-3 border-t border-neutral-200 py-6 text-xs text-neutral-500 sm:flex-row sm:items-center sm:justify-between">
          <p class="flex flex-wrap items-center gap-x-2 gap-y-1">
            <span class="font-medium text-neutral-700">© {new Date().getFullYear()} nodrix</span>
            <span class="text-neutral-300" aria-hidden="true">·</span>
            <a href={`${repoUrl}/blob/master/LICENSE`} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-accent-600">MIT License</a>
            <span class="text-neutral-300" aria-hidden="true">·</span>
            <a href={`${repoUrl}/releases`} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-accent-600">v1.0</a>
          </p>
          <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
            <a href="/privacy" class="transition-colors hover:text-accent-600">Privacy Policy</a>
            <a href="/terms" class="transition-colors hover:text-accent-600">Terms of Use</a>
          </div>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        const btn = document.getElementById('menu-toggle');
        const menu = document.getElementById('mobile-menu');
        const open = document.getElementById('icon-open');
        const close = document.getElementById('icon-close');
        if (!btn || !menu) return;
        btn.addEventListener('click', function () {
          const isOpen = menu.classList.toggle('hidden') === false;
          btn.setAttribute('aria-expanded', String(isOpen));
          open.classList.toggle('hidden', isOpen);
          close.classList.toggle('hidden', !isOpen);
        });
        menu.querySelectorAll('a').forEach(function (a) {
          a.addEventListener('click', function () {
            menu.classList.add('hidden');
            btn.setAttribute('aria-expanded', 'false');
            open.classList.remove('hidden');
            close.classList.add('hidden');
          });
        });
      })();
    </script>
  </body>
</html>
