{
  "name": "@nodrix/promo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "astro build && wrangler pages deploy dist --project-name nodrix",
    "typecheck": "astro check",
    "icons": "bun scripts/generate-icons.js",
    "db:schema": "wrangler d1 execute nodrix-wishlist --remote --file=./schema.sql",
    "db:schema:local": "wrangler d1 execute nodrix-wishlist --local --file=./schema.sql",
    "wishlist:list": "wrangler d1 execute nodrix-wishlist --remote --command \"SELECT email, created_at FROM wishlist ORDER BY created_at DESC\""
  },
  "dependencies": {
    "astro": "6.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@tailwindcss/vite": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.28.1"
  }
}
