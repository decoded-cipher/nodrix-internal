---
export interface Props {
  repo?: string;
  label?: string;
}

const repoUrl = Astro.props.repo ?? 'https://github.com/decoded-cipher/nodrix';
const label = Astro.props.label ?? 'Deploy to Cloudflare';
const deployUrl = `https://deploy.workers.cloudflare.com/?url=${encodeURIComponent(repoUrl)}`;
---

<a
  href={deployUrl}
  class="inline-flex items-center gap-2 rounded-md bg-orange-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-orange-700"
>
  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12 2L2 12h3v8h5v-6h4v6h5v-8h3L12 2z"/>
  </svg>
  {label}
</a>
