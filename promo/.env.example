# Copy to `.env` (gitignored) and fill in for production builds.
#
# Cloudflare Turnstile PUBLIC site key (safe to expose). Without it, the build
# falls back to Cloudflare's always-pass TEST key so local dev works.
# The matching secret is NOT set here — it's a Pages secret:
#   npx wrangler pages secret put TURNSTILE_SECRET_KEY
PUBLIC_TURNSTILE_SITEKEY=
