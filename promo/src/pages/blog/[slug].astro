---
import { getCollection, render } from 'astro:content';
import Site from '../../layouts/Site.astro';
import Waves from '../../components/Waves.astro';
import CtaBand from '../../components/CtaBand.astro';
import Faq from '../../components/Faq.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { breadcrumb, faqPage, jsonLdGraph, readingTime } from '../../lib/seo';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((p) => ({ params: { slug: p.id }, props: { post: p } }));
}

const { post } = Astro.props;
const fm = post.data;
const { Content } = await render(post);
const minutes = readingTime(post.body ?? '');
const ogPath = `/og/blog/${post.id}.png`; // pre-generated by `bun run og:gen`

const TYPE_LABEL: Record<string, string> = {
  release: 'Release',
  engineering: 'Engineering',
  'case-study': 'Case study',
};

const site = Astro.site!;
const path = `/blog/${post.id}`;
const updated = fm.dateUpdated ?? fm.datePublished;

// Omitted author → authored by the org; a byline → a Person.
const authorName = fm.author?.name ?? 'nodrix';
const authorInitials = authorName
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((w) => w[0]!.toUpperCase())
  .join('');
const authorNode = fm.author
  ? { '@type': 'Person', name: fm.author.name, ...(fm.author.url ? { url: fm.author.url } : {}) }
  : { '@type': 'Organization', name: 'nodrix', url: site.href };

const nodes: object[] = [
  {
    '@type': 'BlogPosting',
    headline: fm.title,
    description: fm.description,
    image: new URL(ogPath, site).href,
    datePublished: fm.datePublished.toISOString(),
    dateModified: updated.toISOString(),
    inLanguage: 'en',
    url: new URL(path, site).href,
    mainEntityOfPage: new URL(path, site).href,
    author: authorNode,
    publisher: { '@id': new URL('#org', site).href },
    isPartOf: { '@id': new URL('#website', site).href },
  },
  breadcrumb(site, [
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog' },
    { name: fm.title, path },
  ]),
];
if (fm.faqs.length) nodes.push(faqPage(fm.faqs));
const jsonLd = jsonLdGraph(...nodes);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Site
  title={`${fm.title} | nodrix`}
  description={fm.description}
  type="article"
  image={ogPath}
>
  <Fragment slot="head">
    <link rel="alternate" type="application/rss+xml" title="nodrix blog" href={new URL('blog/rss.xml', site).href} />
    <script is:inline type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <!-- Hero -->
  <section class="hero-glow relative overflow-hidden border-b border-neutral-200/70">
    <Waves />
    <div class="relative mx-auto max-w-4xl px-5 py-12 sm:px-6 sm:py-16">
      <nav class="text-sm text-neutral-500" aria-label="Breadcrumb">
        <a href="/blog" class="font-semibold text-accent-600 hover:text-accent-700">Blog</a>
        <span class="mx-1.5 text-neutral-300">/</span>
        <span>{TYPE_LABEL[fm.type]}</span>
      </nav>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <span class="rounded-full bg-accent-50 px-3 py-1 text-xs font-semibold text-accent-700">{TYPE_LABEL[fm.type]}</span>
        {fm.version && (
          <a href="/changelog" class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-semibold text-neutral-600 transition-colors hover:bg-neutral-200">v{fm.version}</a>
        )}
        {fm.tags.map((t) => (
          <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-semibold text-neutral-600">{t}</span>
        ))}
        <span class="text-xs font-medium text-neutral-400">{minutes}</span>
        {fm.draft && <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700">Draft</span>}
      </div>
      <h1 class="mt-4 text-balance text-3xl font-extrabold tracking-tight text-neutral-900 sm:text-4xl">
        {fm.title}
      </h1>
      <p class="mt-4 text-pretty text-base leading-relaxed text-neutral-600 sm:text-lg">{fm.description}</p>
      <div class="mt-6 flex items-center gap-3">
        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-accent-100 text-sm font-bold text-accent-700" aria-hidden="true">{authorInitials}</div>
        <div class="text-sm leading-tight">
          <div class="font-semibold text-neutral-900">
            {fm.author?.url
              ? <a href={fm.author.url} class="transition-colors hover:text-accent-600" target="_blank" rel="noopener noreferrer">{authorName}</a>
              : authorName}
          </div>
          <div class="mt-0.5 text-xs text-neutral-500">
            {fm.author?.role ? `${fm.author.role} · ` : ''}Updated {fmtDate(updated)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Article -->
  <section class="bg-white">
    <div class="mx-auto max-w-4xl px-5 py-12 sm:px-6 sm:py-16">
      <article class="prose prose-neutral max-w-none
        prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-neutral-900
        prose-h2:mt-12 prose-h2:text-2xl prose-h3:text-lg
        prose-a:font-medium prose-a:text-accent-600 hover:prose-a:text-accent-700">
        <Content />
      </article>
    </div>
  </section>

  {fm.faqs.length > 0 && <Faq items={fm.faqs} />}
  {fm.related.length > 0 && <RelatedLinks links={fm.related} />}
  <CtaBand />

  <script>
    // Add a copy-to-clipboard button to every code block in the article.
    const COPY =
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>';
    const DONE =
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>';

    document.querySelectorAll('article pre').forEach((pre) => {
      const code = pre.querySelector('code');
      if (!code) return;

      const wrap = document.createElement('div');
      wrap.className = 'code-wrap';
      pre.parentNode?.insertBefore(wrap, pre);
      wrap.appendChild(pre);

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'copy-btn';
      btn.setAttribute('aria-label', 'Copy code');
      btn.innerHTML = COPY;

      btn.addEventListener('click', async () => {
        const text = (code.textContent ?? '').replace(/\n$/, '');
        try {
          await navigator.clipboard.writeText(text);
          btn.innerHTML = DONE;
          btn.classList.add('copied');
          btn.setAttribute('aria-label', 'Copied');
          setTimeout(() => {
            btn.innerHTML = COPY;
            btn.classList.remove('copied');
            btn.setAttribute('aria-label', 'Copy code');
          }, 1600);
        } catch {
          /* clipboard unavailable */
        }
      });

      wrap.appendChild(btn);
    });
  </script>
</Site>
