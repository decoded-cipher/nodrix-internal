---
import Site from '../layouts/Site.astro';
import DeployButton from '../components/DeployButton.astro';

const repoUrl = 'https://github.com/decoded-cipher/nodrix';

const stack = [
  { name: 'Workers', icon: 'M13 2 3 14h9l-1 8 10-12h-9l1-8z' },
  { name: 'Durable Objects', icon: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z M3.3 7 12 12l8.7-5 M12 22V12' },
  { name: 'D1', icon: 'M12 8c4.97 0 9-1.34 9-3s-4.03-3-9-3-9 1.34-9 3 4.03 3 9 3z M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5 M3 12c0 1.66 4 3 9 3s9-1.34 9-3' },
  { name: 'R2', icon: 'M22 12H2 M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z M6 16h.01 M10 16h.01' },
  { name: 'KV', icon: 'M2.59 17.41A2 2 0 0 0 2 18.83V21a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h1a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h.17a2 2 0 0 0 1.42-.59l.81-.81a6.5 6.5 0 1 0-4-4z M16.5 7.5h.01' },
];

const features = [
  {
    title: 'Telemetry over plain HTTPS',
    body: 'Hardware POSTs JSON to your project. Variables create themselves on first sight — no schema to declare, no MQTT broker to run, no SDK to install. If it can make an HTTPS request, it can talk to nodrix.',
    icon: 'm4 14 5-5 4 4 7-7 M21 14V6h-8',
  },
  {
    title: 'Realtime drag-and-drop dashboards',
    body: 'Drop widgets onto a grid, bind them to variables, and watch values update live over hibernating WebSockets that cost nothing while they sit idle.',
    icon: 'M3 4h18v16H3z M3 9h18 M9 9v11',
  },
  {
    title: 'Control that flows both ways',
    body: 'Toggles, sliders, and buttons write values back down. Hardware picks them up over a short poll or a WebSocket, applies them, and acks when done.',
    icon: 'M7 8 3 12l4 4 M17 8l4 4-4 4 M14 4l-4 16',
  },
  {
    title: 'Automations without a server',
    body: 'Fire on a variable threshold, a clock, sunrise / sunset, or a custom event. Then set variables, call webhooks, or ping Slack — all running at the edge.',
    icon: 'M13 2 4 14h7l-1 8 9-12h-7z',
  },
  {
    title: 'A clean read API',
    body: 'Edge-cached latest state, recent time-series, and variable listings behind one bearer token. Plug in Grafana, a React app, or a Raspberry Pi screen.',
    icon: 'M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1 M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1',
  },
  {
    title: 'Single-tenant by design',
    body: 'Every deploy lands in your own account, on your own D1, R2, and Durable Objects. Email + password out of the box, with optional Google or GitHub sign-in.',
    icon: 'M12 2 4 5v6c0 5 3.5 8 8 11 4.5-3 8-6 8-11V5z',
  },
];

const steps = [
  {
    title: 'Deploy in one click',
    body: 'Hit Deploy to Cloudflare. It provisions D1, R2, KV, and the Worker straight into your account — nothing to host, nothing to maintain.',
  },
  {
    title: 'Claim your instance',
    body: 'Open the worker URL and create the first account. It becomes the owner. Spin up your first project in a couple of clicks.',
  },
  {
    title: 'Connect your hardware',
    body: 'Mint a project token and point your device at /v1/telemetry. Variables show up the moment data starts flowing.',
  },
  {
    title: 'Build & automate',
    body: 'Compose a dashboard, bind widgets to variables, and wire automations to act on the data — or hand it off through the read API.',
  },
];

const widgets = [
  { name: 'iot-value', kind: 'Display', desc: 'Latest reading of a variable.' },
  { name: 'iot-gauge', kind: 'Display', desc: 'Arc gauge with min / max bounds.' },
  { name: 'iot-chart', kind: 'Display', desc: 'Multi-series time-series chart.' },
  { name: 'iot-toggle', kind: 'Control', desc: 'On / off write to a variable.' },
  { name: 'iot-slider', kind: 'Control', desc: 'Numeric write, committed on release.' },
  { name: 'iot-push', kind: 'Control', desc: 'Momentary one-shot command.' },
];

---

<Site
  title="nodrix — your own IoT cloud, on Cloudflare"
  description="Open-source, single-tenant IoT platform that deploys to your own Cloudflare account. Hardware over HTTPS, realtime dashboards, automations, and a clean read API."
>
  <!-- Hero -->
  <section class="hero-glow relative flex min-h-[calc(100svh-3.5rem)] items-center overflow-hidden border-b border-neutral-200/70">
    <div class="bg-dotgrid absolute inset-0 opacity-70"></div>
    <div class="relative mx-auto w-full max-w-6xl px-5 py-16 text-center sm:px-6 sm:py-24">
      <a
        href={repoUrl}
        class="rise group inline-flex items-center gap-2.5 rounded-full border border-neutral-200 bg-white/80 py-1 pl-1 pr-3.5 text-xs font-medium text-neutral-600 shadow-sm backdrop-blur transition-colors hover:border-neutral-300 hover:text-neutral-900"
      >
        <span class="inline-flex items-center gap-1.5 rounded-full bg-accent-50 px-2 py-0.5 font-semibold text-accent-700 ring-1 ring-inset ring-accent-100">
          <span class="relative flex h-1.5 w-1.5">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-400 opacity-75"></span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-accent-500"></span>
          </span>
          Pre-alpha
        </span>
        <span class="inline-flex items-center gap-2">
          <span>Open source</span>
          <span class="h-3 w-px bg-neutral-300" aria-hidden="true"></span>
          <span>Star it on GitHub</span>
        </span>
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
      </a>

      <h1 class="rise mx-auto mt-7 max-w-6xl text-balance text-4xl font-extrabold leading-[1.05] tracking-tight text-neutral-900 sm:text-5xl lg:text-6xl">
        Your own IoT cloud.<br />
        <span class="text-accent-500 xl:whitespace-nowrap">Running on your Cloudflare account.</span>
      </h1>

      <p class="rise mx-auto mt-6 max-w-3xl text-pretty text-base leading-relaxed text-neutral-600 sm:text-lg">
        <span class="sm:hidden">
          An open-source IoT backend that runs in your own Cloudflare account — no broker, no servers,
          no middleman.
        </span>
        <span class="hidden sm:inline">
          An open-source IoT backend that lives in your Cloudflare account. Hardware speaks plain HTTPS,
          data streams to drag-and-drop dashboards in realtime, and a clean read API hands it to anything
          else you build — no broker, no servers, no third party in the middle.
        </span>
      </p>

      <div class="rise mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <DeployButton repo={repoUrl} size="lg" class="w-full sm:w-60" />
        <a
          href={repoUrl}
          class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-neutral-300 bg-white px-6 py-3.5 text-base font-semibold text-neutral-900 transition-colors hover:bg-neutral-50 sm:w-60"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.4.5 0 5.9 0 12.5c0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 24 12.5C24 5.9 18.6.5 12 .5Z"/></svg>
          Star on GitHub
        </a>
      </div>

      <p class="rise mt-4 text-xs text-neutral-500">
        One-click deploy · Single-tenant · Your data never leaves your account
      </p>

      <div class="rise mt-14">
        <p class="text-xs font-medium uppercase tracking-widest text-neutral-400">
          Runs entirely on your Cloudflare primitives
        </p>
        <div class="mt-5 flex flex-wrap items-center justify-center gap-2 sm:gap-2.5">
          {stack.map((s) => (
            <span class="group inline-flex items-center gap-2 rounded-full border border-neutral-200 bg-white/70 px-3 py-1 text-xs font-semibold text-neutral-600 shadow-sm backdrop-blur transition-colors hover:border-accent-200 hover:text-accent-600 sm:gap-2 sm:px-3.5 sm:py-1.5 sm:text-sm">
              <svg class="h-3.5 w-3.5 text-neutral-400 transition-colors group-hover:text-accent-500 sm:h-4 sm:w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={s.icon} />
              </svg>
              {s.name}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="scroll-mt-20 border-b border-neutral-200/70 bg-white">
    <div class="mx-auto max-w-6xl px-5 py-20 sm:px-6 sm:py-28">
      <div class="max-w-2xl">
        <span class="text-sm font-semibold text-accent-600">Everything in one Worker</span>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl">
          A complete IoT backend, deployed to a URL you own.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-neutral-600">
          Ingest, store, visualize, control, and automate — without standing up a single server or
          trusting a vendor with your data.
        </p>
      </div>

      <div class="mt-12 grid gap-px overflow-hidden rounded-2xl border border-neutral-200 bg-neutral-200 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <div class="group bg-white p-6 transition-colors hover:bg-neutral-50 sm:p-8">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-accent-50 text-accent-600 ring-1 ring-inset ring-accent-100">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={f.icon} />
              </svg>
            </div>
            <h3 class="mt-5 text-lg font-semibold text-neutral-900">{f.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-neutral-600">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Code showcase -->
  <section class="border-b border-neutral-200/70 bg-neutral-50">
    <div class="mx-auto grid max-w-6xl items-center gap-10 px-5 py-20 sm:px-6 sm:py-28 lg:grid-cols-2 lg:gap-16">
      <div class="min-w-0">
        <span class="text-sm font-semibold text-accent-600">No SDK required</span>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl">
          Speak HTTPS, get a dashboard.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-neutral-600">
          Point any client at your worker URL with a project token. Send a metric and it becomes a
          variable you can chart, gauge, and control — instantly. Read it back from anywhere over a
          plain, edge-cached REST call.
        </p>
        <a href="/docs" class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-accent-600 hover:text-accent-700">
          Read the full protocol
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="min-w-0 space-y-4">
        <div class="overflow-hidden rounded-xl border border-neutral-800 bg-neutral-900 shadow-xl shadow-neutral-900/10">
          <div class="flex items-center gap-2 border-b border-neutral-800 px-4 py-2.5">
            <span class="h-2.5 w-2.5 rounded-full bg-neutral-700"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-neutral-700"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-neutral-700"></span>
            <span class="ml-2 text-xs font-medium text-neutral-500">send telemetry</span>
          </div>
          <pre class="overflow-x-auto p-4 text-xs leading-relaxed text-neutral-200 sm:text-[13px]"><code><span class="text-accent-400">POST</span> /v1/telemetry  <span class="text-neutral-500">Authorization: Bearer &lt;token&gt;</span>
{`{ "metrics": { "temperature": 23.4, "humidity": 61 } }`}

<span class="text-emerald-400">→ 204 No Content</span>  <span class="text-neutral-500"># variables auto-created</span></code></pre>
        </div>

        <div class="overflow-hidden rounded-xl border border-neutral-800 bg-neutral-900 shadow-xl shadow-neutral-900/10">
          <div class="flex items-center gap-2 border-b border-neutral-800 px-4 py-2.5">
            <span class="h-2.5 w-2.5 rounded-full bg-neutral-700"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-neutral-700"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-neutral-700"></span>
            <span class="ml-2 text-xs font-medium text-neutral-500">read it back</span>
          </div>
          <pre class="overflow-x-auto p-4 text-xs leading-relaxed text-neutral-200 sm:text-[13px]"><code><span class="text-accent-400">GET</span> /v1/projects/:proj/state

<span class="text-emerald-400">→</span> {`{ "temperature": { "value": 23.4, "received_at": 171590… } }`}</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how" class="scroll-mt-20 border-b border-neutral-200/70 bg-white">
    <div class="mx-auto max-w-6xl px-5 py-20 sm:px-6 sm:py-28">
      <div class="max-w-2xl">
        <span class="text-sm font-semibold text-accent-600">From zero to live</span>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl">
          Four steps to a running instance.
        </h2>
      </div>

      <ol class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {steps.map((s, i) => (
          <li class="relative">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-neutral-900 text-sm font-bold text-white">
              {i + 1}
            </div>
            <h3 class="mt-4 text-base font-semibold text-neutral-900">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-neutral-600">{s.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Widgets teaser -->
  <section class="border-b border-neutral-200/70 bg-neutral-50">
    <div class="mx-auto max-w-6xl px-5 py-20 sm:px-6 sm:py-28">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <span class="text-sm font-semibold text-accent-600">Batteries included</span>
          <h2 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl">
            Drop-in widgets, ready to bind.
          </h2>
          <p class="mt-4 text-base leading-relaxed text-neutral-600">
            Framework-agnostic Web Components that take data in and emit command intents out — embed
            them anywhere, not just here. The library keeps growing.
          </p>
        </div>
        <a href="/widgets" class="inline-flex shrink-0 items-center gap-1.5 text-sm font-semibold text-accent-600 hover:text-accent-700">
          Browse the widgets <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {widgets.map((w) => (
          <div class="rounded-xl border border-neutral-200 bg-white p-5 transition-shadow hover:shadow-sm">
            <div class="flex items-center justify-between">
              <code class="font-mono text-sm font-semibold text-neutral-900">{w.name}</code>
              <span class={`rounded-full px-2 py-0.5 text-[11px] font-semibold ${w.kind === 'Control' ? 'bg-accent-50 text-accent-700' : 'bg-neutral-100 text-neutral-600'}`}>{w.kind}</span>
            </div>
            <p class="mt-2 text-sm text-neutral-600">{w.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-20 sm:px-6 sm:py-24">
      <div class="hero-glow relative overflow-hidden rounded-3xl bg-neutral-900 px-6 py-14 text-center sm:px-12 sm:py-20">
        <div class="bg-dotgrid absolute inset-0 opacity-10" style="background-image: radial-gradient(rgba(255,255,255,0.12) 1px, transparent 1px);"></div>
        <div class="relative">
          <picture>
            <source srcset="/white_logo.webp" type="image/webp" />
            <img src="/white_logo.png" alt="nodrix" class="mx-auto h-8 w-auto sm:h-10" width="160" height="46" />
          </picture>
          <h2 class="mx-auto mt-6 max-w-2xl text-balance text-3xl font-bold tracking-tight text-white sm:text-4xl">
            Spin up your own IoT cloud in a click.
          </h2>
          <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-neutral-400">
            Free, open source, and entirely yours. It's pre-alpha and moving fast — star the repo to
            follow along and deploy the moment it's ready.
          </p>
          <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
            <DeployButton repo={repoUrl} size="lg" class="w-full sm:w-60" />
            <a
              href={repoUrl}
              class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-neutral-700 bg-neutral-800 px-6 py-3.5 text-base font-semibold text-white transition-colors hover:bg-neutral-700 sm:w-60"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.4.5 0 5.9 0 12.5c0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 24 12.5C24 5.9 18.6.5 12 .5Z"/></svg>
              Star on GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Site>
