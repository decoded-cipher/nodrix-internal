---
import Site from '../layouts/Site.astro';
import Waves from '../components/Waves.astro';
import CtaBand from '../components/CtaBand.astro';
import { breadcrumb, jsonLdGraph } from '../lib/seo';

const title = 'Products';
const description =
  'The nodrix universe — the open-source libraries, components, and tools built around the core IoT cloud: the Arduino library for ESP32 and ESP8266, the built-in dashboard widgets, and the open device protocol any board can speak.';

const featured = {
  name: 'Nodrix Arduino Library',
  href: '/products/arduino-library',
  tagline: 'ESP32 & ESP8266 · C++',
  desc: 'Connect hardware in a few lines. It hides WiFi, TLS, the WebSocket/HTTP transport, JSON, and the control/telemetry protocol behind a tiny API — NODRIX_WRITE control handlers, one-call telemetry, multi-WiFi failover, and TLS pinning.',
  tags: ['Arduino IDE', 'PlatformIO', 'MIT', 'v0.1.0'],
  icon: 'M6 6h12v12H6z M9 9h6v6H9z M9 2v2 M15 2v2 M9 20v2 M15 20v2 M2 9h2 M2 15h2 M20 9h2 M20 15h2',
};

const others = [
  {
    name: 'Dashboard widgets',
    href: '/widgets',
    desc: 'Framework-agnostic Web Components for displaying and controlling variables — value, gauge, chart, map, toggle, slider, and push. Use them on the built-in dashboard or in your own app.',
    icon: 'M3 3h7v7H3z M14 3h7v7h-7z M14 14h7v7h-7z M3 14h7v7H3z',
    cta: 'Browse widgets',
  },
  {
    name: 'MCP server',
    href: '/docs#mcp',
    desc: 'Point Claude, ChatGPT, or any MCP client at your instance. Owner-gated and off by default, it reads your projects and — with an explicit toggle — drives your automations.',
    icon: 'M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0Z M20 3v4 M22 5h-4 M4 17v2 M5 18H3',
    cta: 'Read the MCP docs',
  },
  {
    name: 'The open device protocol',
    href: '/docs#protocol',
    desc: 'No library required. The protocol is plain HTTPS and WebSocket with JSON, so any board or language talks to nodrix directly — a Raspberry Pi, a server script, an Arduino UNO R4, anything that can make a request.',
    icon: 'M18 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6z M6 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z M18 22a3 3 0 1 0 0-6 3 3 0 0 0 0 6z M8.59 13.51l6.83 3.98 M15.41 6.51l-6.82 3.98',
    cta: 'Read the protocol',
  },
];

const site = Astro.site!;
const jsonLd = jsonLdGraph(
  {
    '@type': 'CollectionPage',
    name: 'Products — nodrix',
    description,
    url: new URL('products', site).href,
    isPartOf: { '@id': new URL('#website', site).href },
  },
  breadcrumb(site, [
    { name: 'Home', path: '/' },
    { name: 'Products', path: '/products' },
  ]),
);

const tile = 'flex items-center justify-center rounded-xl bg-accent-50 text-accent-600 ring-1 ring-inset ring-accent-100';
const svgAttrs = { viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', 'stroke-width': '1.8', 'stroke-linecap': 'round', 'stroke-linejoin': 'round', 'aria-hidden': 'true' };
---

<Site title={`${title} — nodrix`} description={description}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- Hero -->
  <section class="hero-glow relative overflow-hidden border-b border-neutral-200/70">
    <Waves />
    <div class="relative mx-auto max-w-4xl px-5 py-16 sm:px-6 sm:py-24">
      <span class="text-sm font-semibold text-accent-600">Products</span>
      <h1 class="mt-2 text-balance text-4xl font-extrabold tracking-tight text-neutral-900 sm:text-5xl">
        The nodrix universe.
      </h1>
      <p class="mt-5 max-w-2xl text-pretty text-base leading-relaxed text-neutral-600 sm:text-lg">
        Nodrix is the open-source IoT cloud. Around it we build the pieces that plug into it — a library
        for your hardware, components for your dashboards, and the open protocol that ties them together.
        All MIT-licensed, all optional, all yours.
      </p>
    </div>
  </section>

  <!-- Featured product -->
  <section class="border-b border-neutral-200/70 bg-white">
    <div class="mx-auto max-w-5xl px-5 py-16 sm:px-6 sm:py-20">
      <a
        href={featured.href}
        class="group block overflow-hidden rounded-2xl border border-neutral-200 bg-white transition-all hover:border-accent-200 hover:shadow-lg"
      >
        <div class="flex flex-col gap-6 p-7 sm:flex-row sm:items-start sm:p-9">
          <div class={`${tile} h-14 w-14 shrink-0`}>
            <svg class="h-7 w-7" {...svgAttrs}><path d={featured.icon} /></svg>
          </div>
          <div class="min-w-0">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
              <h2 class="text-xl font-bold tracking-tight text-neutral-900 sm:text-2xl">{featured.name}</h2>
              <span class="rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-semibold text-emerald-700 ring-1 ring-inset ring-emerald-100">Available now</span>
            </div>
            <p class="mt-1 text-sm font-semibold text-accent-600">{featured.tagline}</p>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-neutral-600">{featured.desc}</p>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {featured.tags.map((t) => (
                <span class="rounded-full border border-neutral-200 bg-neutral-50 px-2.5 py-0.5 text-[11px] font-medium text-neutral-500">{t}</span>
              ))}
            </div>
            <span class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-accent-600 group-hover:text-accent-700">
              Explore the library
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
            </span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- Other ways to connect -->
  <section class="border-b border-neutral-200/70 bg-neutral-50">
    <div class="mx-auto max-w-5xl px-5 py-16 sm:px-6 sm:py-20">
      <span class="text-sm font-semibold text-accent-600">Ecosystem</span>
      <h2 class="mt-2 text-2xl font-bold tracking-tight text-neutral-900 sm:text-3xl">The rest of the ecosystem</h2>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {others.map((o) => (
          <a href={o.href} class="group flex min-w-0 flex-col rounded-2xl border border-neutral-200 bg-white p-6 transition-all hover:border-accent-200 hover:shadow-md">
            <div class={`${tile} h-11 w-11`}>
              <svg class="h-5 w-5" {...svgAttrs}><path d={o.icon} /></svg>
            </div>
            <h3 class="mt-4 text-base font-bold text-neutral-900">{o.name}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-neutral-600">{o.desc}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-accent-600 group-hover:text-accent-700">
              {o.cta}
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
            </span>
          </a>
        ))}
      </div>
      <p class="mt-8 text-sm text-neutral-500">
        More pieces of the universe are in the works — see what's next on the
        <a href="/roadmap" class="font-semibold text-accent-600 hover:text-accent-700">roadmap</a>.
      </p>
    </div>
  </section>

  <CtaBand />
</Site>
