---
import { getCollection } from 'astro:content';
import Site from '../../layouts/Site.astro';
import Waves from '../../components/Waves.astro';
import CtaBand from '../../components/CtaBand.astro';
import { breadcrumb, itemList, jsonLdGraph, readingTime } from '../../lib/seo';

const TYPE_LABEL: Record<string, string> = {
  release: 'Release',
  engineering: 'Engineering',
  'case-study': 'Case study',
};

const all = await getCollection('blog');
const byDate = (a: { data: { datePublished: Date } }, b: { data: { datePublished: Date } }) =>
  b.data.datePublished.getTime() - a.data.datePublished.getTime();

const published = all.filter((p) => !p.data.draft).sort(byDate);
const upcoming = all.filter((p) => p.data.draft).sort(byDate);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const site = Astro.site!;
const jsonLd = jsonLdGraph(
  itemList(
    'nodrix blog',
    'Release notes, build-in-public engineering stories, and case studies from the team building nodrix.',
    published.map((p) => ({ name: p.data.title, description: p.data.description })),
  ),
  breadcrumb(site, [
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog' },
  ]),
);
---

<Site
  title="Blog — release notes, engineering, and case studies | nodrix"
  description="Release notes, build-in-public engineering stories, and case studies from the team building nodrix — the open-source IoT platform that deploys to your own Cloudflare account."
>
  <Fragment slot="head">
    <link rel="alternate" type="application/rss+xml" title="nodrix blog" href={new URL('blog/rss.xml', site).href} />
    <script is:inline type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <section class="hero-glow relative overflow-hidden border-b border-neutral-200/70">
    <Waves />
    <div class="relative mx-auto max-w-4xl px-5 py-16 sm:px-6 sm:py-24">
      <span class="text-sm font-semibold text-accent-600">Blog</span>
      <h1 class="mt-2 text-balance text-4xl font-extrabold tracking-tight text-neutral-900 sm:text-5xl">
        Notes from building nodrix.
      </h1>
      <p class="mt-5 max-w-2xl text-pretty text-base leading-relaxed text-neutral-600 sm:text-lg">
        Release notes for the milestones that matter, the engineering decisions behind the platform,
        and stories from people running their own IoT cloud on nodrix. For the tight
        version-by-version list, see the
        <a href="/changelog" class="font-semibold text-accent-600 hover:text-accent-700">changelog</a>.
      </p>
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto max-w-5xl px-5 py-16 sm:px-6 sm:py-20">
      <div class="grid gap-5 md:grid-cols-2">
        {published.map((p) => {
          const author = p.data.author?.name ?? 'nodrix';
          const initials = author
            .split(/\s+/)
            .filter(Boolean)
            .slice(0, 2)
            .map((w) => w[0]!.toUpperCase())
            .join('');
          return (
          <a
            href={`/blog/${p.id}`}
            class="group flex flex-col rounded-2xl border border-neutral-200 bg-white p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-accent-200 hover:shadow-lg hover:shadow-accent-500/5"
          >
            <div class="flex items-center gap-2">
              <span class="rounded-full bg-accent-50 px-2.5 py-0.5 text-[11px] font-semibold text-accent-700">{TYPE_LABEL[p.data.type]}</span>
              {p.data.version && <span class="rounded-full bg-neutral-100 px-2.5 py-0.5 text-[11px] font-semibold text-neutral-600">v{p.data.version}</span>}
              <span class="ml-auto text-[11px] text-neutral-400">{readingTime(p.body ?? '')}</span>
            </div>

            <h2 class="mt-4 text-xl font-bold leading-snug tracking-tight text-neutral-900 transition-colors group-hover:text-accent-700">{p.data.title}</h2>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-neutral-600 line-clamp-3">{p.data.description}</p>

            <div class="mt-5 flex items-center gap-3 border-t border-neutral-100 pt-4">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-accent-100 text-xs font-bold text-accent-700" aria-hidden="true">{initials}</div>
              <div class="min-w-0 text-xs leading-tight">
                <div class="truncate font-semibold text-neutral-800">{author}</div>
                <div class="mt-0.5 text-neutral-400">{p.data.author?.role ? `${p.data.author.role} · ` : ''}{fmtDate(p.data.datePublished)}</div>
              </div>
              <span class="ml-auto inline-flex items-center gap-1 text-sm font-semibold text-accent-600">
                Read <span class="transition-transform group-hover:translate-x-0.5" aria-hidden="true">→</span>
              </span>
            </div>
          </a>
          );
        })}
      </div>

      {upcoming.length > 0 && (
        <div class="mt-12">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-neutral-400">Coming soon</h2>
          <div class="mt-4 grid gap-5 md:grid-cols-2">
            {upcoming.map((p) => (
              <a
                href={`/blog/${p.id}`}
                class="group flex flex-col rounded-2xl border border-dashed border-neutral-200 bg-neutral-50/60 p-6 transition-colors hover:bg-neutral-50"
              >
                <div class="flex items-center gap-2">
                  <span class="rounded-full bg-neutral-100 px-2.5 py-0.5 text-[11px] font-semibold text-neutral-500">{TYPE_LABEL[p.data.type]}</span>
                  <span class="ml-auto rounded-full bg-amber-100 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-amber-700">Draft</span>
                </div>
                <h3 class="mt-3 text-base font-semibold leading-snug text-neutral-700">{p.data.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-neutral-500">{p.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <CtaBand />
</Site>
