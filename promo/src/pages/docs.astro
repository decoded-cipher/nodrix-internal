---
import Site from '../layouts/Site.astro';
import DeployButton from '../components/DeployButton.astro';
import Waves from '../components/Waves.astro';

const toc = [
  { href: '#setup', label: 'Deploy & claim' },
  { href: '#tokens', label: 'Tokens' },
  { href: '#protocol', label: 'Device protocol' },
  { href: '#dashboards', label: 'Dashboards' },
  { href: '#read-api', label: 'Read API' },
  { href: '#automations', label: 'Automations' },
  { href: '#mcp', label: 'MCP (AI clients)' },
];

const site = Astro.site!;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TechArticle',
      headline: 'nodrix documentation',
      description:
        'Deploy, claim, and connect: the nodrix device protocol, dashboards, read API, and automation model.',
      url: new URL('docs', site).href,
      inLanguage: 'en',
      isPartOf: { '@id': new URL('#website', site).href },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: site.href },
        { '@type': 'ListItem', position: 2, name: 'Docs', item: new URL('docs', site).href },
      ],
    },
  ],
};
---

<Site
  title="Docs — nodrix"
  description="Deploy, claim, and connect: the nodrix device protocol, dashboards, read API, and automation model."
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <!-- Header -->
  <section class="hero-glow relative overflow-hidden border-b border-neutral-200/70">
    <Waves />
    <div class="relative mx-auto max-w-6xl px-5 py-14 sm:px-6 sm:py-20">
      <span class="text-sm font-semibold text-accent-600">Docs</span>
      <h1 class="mt-2 text-balance text-4xl font-extrabold tracking-tight text-neutral-900 sm:text-5xl">
        Deploy, claim, connect.
      </h1>
      <p class="mt-5 max-w-2xl text-pretty text-base leading-relaxed text-neutral-600 sm:text-lg">
        Get an instance running in your own Cloudflare account, then point hardware at it over plain
        HTTPS. Everything below is the live API surface.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-5 py-12 sm:px-6 sm:py-16 lg:grid lg:grid-cols-[200px_1fr] lg:gap-12">
    <!-- TOC -->
    <aside class="mb-10 lg:mb-0">
      <nav class="lg:sticky lg:top-24">
        <p class="text-xs font-semibold uppercase tracking-wider text-neutral-400">On this page</p>
        <ul data-toc class="mt-3 space-y-1 border-l border-neutral-200">
          {toc.map((t) => (
            <li>
              <a href={t.href} class="-ml-px block border-l-2 border-transparent py-1.5 pl-4 text-sm text-neutral-600 transition-colors hover:border-accent-500 hover:text-neutral-900">{t.label}</a>
            </li>
          ))}
        </ul>
        <a
          href="/docs/arduino-library"
          class="group mt-6 block rounded-xl border border-accent-200/70 bg-gradient-to-b from-accent-50 to-white p-3.5 shadow-sm transition-all hover:border-accent-300 hover:shadow-md"
        >
          <div class="flex items-center justify-between">
            <span class="grid h-8 w-8 place-items-center rounded-lg bg-accent-100 text-accent-600">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="7" y="7" width="10" height="10" rx="1.5" />
                <path d="M10 3v3 M14 3v3 M10 18v3 M14 18v3 M3 10h3 M3 14h3 M18 10h3 M18 14h3" />
              </svg>
            </span>
            <span aria-hidden="true" class="text-accent-400 transition-transform group-hover:translate-x-0.5">→</span>
          </div>
          <p class="mt-2.5 text-[11px] font-semibold uppercase tracking-wider text-accent-600">Library reference</p>
          <p class="mt-0.5 text-sm font-bold text-neutral-900">Arduino library</p>
          <p class="mt-1 text-xs leading-relaxed text-neutral-500">WiFi, TLS, JSON, and acks in a few lines.</p>
          <div class="mt-2.5 flex flex-wrap gap-1">
            <span class="rounded-full border border-neutral-200 bg-white px-1.5 py-0.5 text-[10px] font-medium text-neutral-500">ESP32</span>
            <span class="rounded-full border border-neutral-200 bg-white px-1.5 py-0.5 text-[10px] font-medium text-neutral-500">ESP8266</span>
          </div>
        </a>
      </nav>
    </aside>

    <!-- Content -->
    <main class="min-w-0 max-w-3xl">
      <!-- Setup -->
      <section id="setup" class="scroll-mt-24">
        <h2 class="text-2xl font-bold tracking-tight text-neutral-900">Deploy &amp; claim</h2>
        <p class="mt-4 text-sm leading-relaxed text-neutral-700">
          Deploy the platform to your Cloudflare account. The button provisions D1, R2, KV, and the
          Worker — there's nothing else to host.
        </p>
        <ol class="mt-5 space-y-3 text-sm leading-relaxed text-neutral-700">
          <li class="flex gap-3">
            <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-neutral-900 text-[11px] font-bold text-white">1</span>
            <span>Open your worker URL (e.g. <code class="rounded bg-neutral-100 px-1.5 py-0.5 font-mono text-[13px]">nodrix.&lt;your-subdomain&gt;.workers.dev</code>).</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-neutral-900 text-[11px] font-bold text-white">2</span>
            <span>Register the first account with email + password. It's assigned the <strong>owner</strong> role, and a default project is created for you.</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-neutral-900 text-[11px] font-bold text-white">3</span>
            <span><em>(Optional)</em> Under <strong>Settings → Sign-in providers</strong>, add Google or GitHub OAuth credentials to light up social sign-in.</span>
          </li>
        </ol>
      </section>

      <!-- Tokens -->
      <section id="tokens" class="mt-16 scroll-mt-24">
        <h2 class="text-2xl font-bold tracking-tight text-neutral-900">Tokens</h2>
        <p class="mt-4 text-sm leading-relaxed text-neutral-700">
          Two kinds of bearer token, two audiences. Both are shown once on creation — copy them right
          away.
        </p>
        <div class="mt-5 grid gap-4 sm:grid-cols-2">
          <div class="rounded-xl border border-neutral-200 bg-white p-5">
            <h3 class="font-mono text-sm font-semibold text-neutral-900">Project token</h3>
            <p class="mt-2 text-sm leading-relaxed text-neutral-600">For hardware. Authorizes telemetry, control, and events on one project.</p>
          </div>
          <div class="rounded-xl border border-neutral-200 bg-white p-5">
            <h3 class="font-mono text-sm font-semibold text-neutral-900">User token</h3>
            <p class="mt-2 text-sm leading-relaxed text-neutral-600">For external apps. Authorizes the read-only API. Mint it under <strong>API tokens</strong>.</p>
          </div>
        </div>
      </section>

      <!-- Device protocol -->
      <section id="protocol" class="mt-16 scroll-mt-24">
        <h2 class="text-2xl font-bold tracking-tight text-neutral-900">Device protocol</h2>
        <p class="mt-4 text-sm leading-relaxed text-neutral-700">
          Authenticate every request with your project token:
          <code class="rounded bg-neutral-100 px-1.5 py-0.5 font-mono text-[13px]">Authorization: Bearer &lt;project_token&gt;</code>
        </p>

        <h3 class="mt-8 text-base font-semibold text-neutral-900">Arduino / ESP library</h3>
        <p class="mt-2 text-sm leading-relaxed text-neutral-700">
          On ESP32 and ESP8266, the
          <a href="/docs/arduino-library" class="font-medium text-accent-600 hover:text-accent-700">nodrix Arduino library</a>
          wraps all of this — WiFi, TLS, JSON, control/ack, and reconnects — behind a handful of calls.
          Install it from the Arduino Library Manager or PlatformIO. It speaks exactly the protocol
          below, so you can hit the endpoints directly from any language just as easily.
        </p>
        <pre class="mt-3 overflow-x-auto rounded-xl border border-neutral-800 bg-neutral-900 p-4 text-xs leading-relaxed text-neutral-100 sm:text-[13px]"><code>{`#include <Nodrix.h>

NODRIX_WRITE("relay") {
  digitalWrite(RELAY_PIN, value.asBool());
}

void setup() {
  pinMode(RELAY_PIN, OUTPUT);
  Nodrix.begin(WIFI_SSID, WIFI_PASS, HOST, TOKEN);
}

void loop() {
  Nodrix.run();
  Nodrix.send("temperature", readTemp());
}`}</code></pre>
        <p class="mt-3 text-sm">
          <a href="/docs/arduino-library" class="font-semibold text-accent-600 hover:text-accent-700">Full Arduino library reference →</a>
        </p>

        <h3 class="mt-8 text-base font-semibold text-neutral-900">Send telemetry</h3>
        <p class="mt-2 text-sm leading-relaxed text-neutral-700">
          POST one or many metrics. Keys become variables, auto-created on first sight. Send
          <code class="rounded bg-neutral-100 px-1 py-0.5 font-mono text-[13px]">metrics</code> for a batch, or a single
          <code class="rounded bg-neutral-100 px-1 py-0.5 font-mono text-[13px]">metric</code>/<code class="rounded bg-neutral-100 px-1 py-0.5 font-mono text-[13px]">value</code> pair.
        </p>
        <pre class="mt-3 overflow-x-auto rounded-xl border border-neutral-800 bg-neutral-900 p-4 text-xs leading-relaxed text-neutral-100 sm:text-[13px]"><code><span class="text-accent-400">POST</span> /v1/telemetry
{`{ "metrics": { "temperature": 23.4, "humidity": 61 } }`}
<span class="text-emerald-400">→ 204 No Content</span></code></pre>

        <h3 class="mt-8 text-base font-semibold text-neutral-900">Poll for control writes</h3>
        <p class="mt-2 text-sm leading-relaxed text-neutral-700">
          Dashboard widgets queue value writes for your hardware. Fetch them, apply them, then ack so
          the platform stops resending.
        </p>
        <pre class="mt-3 overflow-x-auto rounded-xl border border-neutral-800 bg-neutral-900 p-4 text-xs leading-relaxed text-neutral-100 sm:text-[13px]"><code><span class="text-accent-400">GET</span> /v1/control
<span class="text-emerald-400">→</span> {`{ "control": [ { "id": "ctl_x", "variable": "relay", "value": "on" } ] }`}

<span class="text-accent-400">POST</span> /v1/control/ack
{`{ "ids": ["ctl_x"] }`}
<span class="text-emerald-400">→</span> {`{ "acked": 1 }`}</code></pre>

        <h3 class="mt-8 text-base font-semibold text-neutral-900">…or over a WebSocket</h3>
        <p class="mt-2 text-sm leading-relaxed text-neutral-700">
          The same operations run over a WebSocket — telemetry up, control writes down, events, and
          acks on one connection. Invalid frames get an error back. Use whichever fits; the HTTP
          endpoints above work just as well.
        </p>
        <pre class="mt-3 overflow-x-auto rounded-xl border border-neutral-800 bg-neutral-900 p-4 text-xs leading-relaxed text-neutral-100 sm:text-[13px]"><code><span class="text-accent-400">WSS</span> /v1/control/ws?token=&lt;project_token&gt;
<span class="text-neutral-500">// up · telemetry</span>
{`{ "type": "telemetry", "metrics": { "temperature": 23.4 } }`}
<span class="text-neutral-500">// up · event</span>
{`{ "type": "event", "event": "door_opened" }`}
<span class="text-neutral-500">// down · control write</span>
{`{ "type": "control", "id": "ctl_x", "variable": "relay", "value": "on" }`}
<span class="text-neutral-500">// up · ack</span>
{`{ "type": "ack", "ids": ["ctl_x"] }`}
<span class="text-neutral-500">// down · rejected input</span>
{`{ "type": "error", "code": "invalid_value", "key": "temperature" }`}</code></pre>

        <h3 class="mt-8 text-base font-semibold text-neutral-900">Emit an event</h3>
        <p class="mt-2 text-sm leading-relaxed text-neutral-700">
          Fire a named event to trigger any matching automation — a button press, a fault, a heartbeat.
        </p>
        <pre class="mt-3 overflow-x-auto rounded-xl border border-neutral-800 bg-neutral-900 p-4 text-xs leading-relaxed text-neutral-100 sm:text-[13px]"><code><span class="text-accent-400">POST</span> /v1/events
{`{ "event": "door_opened", "payload": { "by": "front" } }`}
<span class="text-emerald-400">→ 204 No Content</span></code></pre>
      </section>

      <!-- Dashboards -->
      <section id="dashboards" class="mt-16 scroll-mt-24">
        <h2 class="text-2xl font-bold tracking-tight text-neutral-900">Dashboards</h2>
        <p class="mt-4 text-sm leading-relaxed text-neutral-700">
          Compose dashboards in a full-page, drag-and-drop editor: drop widgets onto a grid and bind
          each to a variable. Readings stream in live over a hibernating WebSocket, and control widgets
          write back — a toggle or slider becomes a control write your hardware receives over its
          control <a href="#protocol" class="font-medium text-accent-600 hover:text-accent-700">socket</a>
          (or its next poll). Seven
          framework-agnostic widgets ship in the box — value, gauge, chart, map, toggle, slider, and
          push, with a separate mobile layout
          (<a href="/widgets" class="font-medium text-accent-600 hover:text-accent-700">browse them →</a>).
        </p>
        <div class="mt-4 flex items-start gap-2.5 rounded-xl border border-neutral-200 bg-neutral-50 p-4">
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-neutral-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="18" cy="5" r="3" /><circle cx="6" cy="12" r="3" /><circle cx="18" cy="19" r="3" /><path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4" />
          </svg>
          <p class="text-sm leading-relaxed text-neutral-600">
            Publish any dashboard read-only at a secret share link — viewers need no account, live
            values arrive by polling, and nothing outside that dashboard's own widgets is ever exposed.
          </p>
        </div>
      </section>

      <!-- Read API -->
      <section id="read-api" class="mt-16 scroll-mt-24">
        <h2 class="text-2xl font-bold tracking-tight text-neutral-900">Read API</h2>
        <p class="mt-4 text-sm leading-relaxed text-neutral-700">
          For external apps — Grafana, a dashboard of your own, a Pi screen. Authenticate with a user
          token:
          <code class="rounded bg-neutral-100 px-1.5 py-0.5 font-mono text-[13px]">Authorization: Bearer &lt;user_token&gt;</code>
        </p>
        <pre class="mt-3 overflow-x-auto rounded-xl border border-neutral-800 bg-neutral-900 p-4 text-xs leading-relaxed text-neutral-100 sm:text-[13px]"><code><span class="text-neutral-500"># every variable in a project</span>
<span class="text-accent-400">GET</span> /v1/projects/:proj/variables

<span class="text-neutral-500"># latest value of every variable (edge-cached)</span>
<span class="text-accent-400">GET</span> /v1/projects/:proj/state

<span class="text-neutral-500"># recent time-series for one variable</span>
<span class="text-accent-400">GET</span> /v1/projects/:proj/variables/:key/series?window=1h</code></pre>
        <p class="mt-3 text-xs text-neutral-500">
          <code class="font-mono">window</code> accepts values like <code class="font-mono">30s</code>, <code class="font-mono">15m</code>, or <code class="font-mono">6h</code> and reads from the recent ring buffer.
        </p>
      </section>

      <!-- Automations -->
      <section id="automations" class="mt-16 scroll-mt-24">
        <h2 class="text-2xl font-bold tracking-tight text-neutral-900">Automations</h2>
        <p class="mt-4 text-sm leading-relaxed text-neutral-700">
          Built in a visual flow editor in the admin UI — no extra code path for your hardware. Each
          automation is a graph: one or more <span class="font-medium text-neutral-900">triggers</span>
          flow through optional <span class="font-medium text-neutral-900">conditions</span> into
          <span class="font-medium text-neutral-900">actions</span>, all evaluated at the edge.
        </p>

        <!-- Visual flow builder mock -->
        <figure class="mt-5 overflow-hidden rounded-xl border border-neutral-200 bg-white shadow-sm">
          <div class="flex items-center gap-2 border-b border-neutral-200 px-4 py-2.5">
            <span class="h-2.5 w-2.5 rounded-full bg-neutral-200"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-neutral-200"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-neutral-200"></span>
            <span class="ml-2 text-xs font-medium text-neutral-500">Freezer guard — flow editor</span>
          </div>
          <div class="overflow-x-auto">
            <div class="relative h-[360px] w-[700px]" style="background-image: radial-gradient(rgb(0 0 0 / 0.06) 1px, transparent 1px); background-size: 16px 16px;">
              <!-- edges (behind nodes) -->
              <svg class="absolute inset-0 h-full w-full" viewBox="0 0 700 360" fill="none" aria-hidden="true">
                <path class="flow-edge" d="M256,78 C292,78 272,180 308,180" stroke="#fb923c" stroke-width="1.5" />
                <path class="flow-edge" d="M256,286 C292,286 272,180 308,180" stroke="#fb923c" stroke-width="1.5" />
                <path class="flow-edge" d="M488,168 C512,168 504,82 528,82" stroke="#10b981" stroke-width="1.5" />
                <path class="flow-edge" d="M488,192 C512,192 504,286 528,286" stroke="#a3a3a3" stroke-width="1.5" />
                <circle cx="256" cy="78" r="3" fill="#fff" stroke="#f97316" stroke-width="1.5" />
                <circle cx="256" cy="286" r="3" fill="#fff" stroke="#f97316" stroke-width="1.5" />
                <circle cx="308" cy="180" r="3" fill="#fff" stroke="#6366f1" stroke-width="1.5" />
                <circle cx="488" cy="168" r="3" fill="#fff" stroke="#10b981" stroke-width="1.5" />
                <circle cx="488" cy="192" r="3" fill="#fff" stroke="#a3a3a3" stroke-width="1.5" />
                <circle cx="528" cy="82" r="3" fill="#fff" stroke="#10b981" stroke-width="1.5" />
                <circle cx="528" cy="286" r="3" fill="#fff" stroke="#10b981" stroke-width="1.5" />
              </svg>

              <!-- palette rail -->
              <div class="absolute inset-y-0 left-0 flex w-11 flex-col items-center gap-2 border-r border-neutral-200 bg-white/60 py-3">
                <span class="grid h-7 w-7 place-items-center rounded-md bg-accent-50 text-accent-600"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 4 14h7l-1 8 9-12h-7z" /></svg></span>
                <span class="grid h-7 w-7 place-items-center rounded-md bg-indigo-50 text-indigo-600"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 4h18l-7 8v6l-4 2v-8z" /></svg></span>
                <span class="grid h-7 w-7 place-items-center rounded-md bg-emerald-50 text-emerald-600"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 5v14l11-7z" /></svg></span>
                <span class="mt-1 grid h-7 w-7 place-items-center rounded-md border border-dashed border-neutral-300 text-neutral-400"><svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14 M5 12h14" /></svg></span>
              </div>

              <!-- nodes -->
              <div class="absolute flex items-center gap-2.5 rounded-lg border border-neutral-200 bg-white px-3 py-2 shadow-sm" style="left:76px;top:49px;width:180px;">
                <span class="grid h-7 w-7 shrink-0 place-items-center rounded-md bg-accent-50 text-accent-600"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13.5V5a2 2 0 1 1 4 0v8.5a4 4 0 1 1-4 0Z" /></svg></span>
                <span class="min-w-0"><span class="block text-[13px] font-semibold leading-tight text-neutral-900">Temperature</span><span class="block text-[11px] text-neutral-500">&gt; -15 °C</span></span>
              </div>
              <div class="absolute flex items-center gap-2.5 rounded-lg border border-neutral-200 bg-white px-3 py-2 shadow-sm" style="left:76px;top:257px;width:180px;">
                <span class="grid h-7 w-7 shrink-0 place-items-center rounded-md bg-accent-50 text-accent-600"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9a6 6 0 0 1 12 0c0 6 2.5 7 2.5 7H3.5S6 15 6 9 M10 20a2 2 0 0 0 4 0" /></svg></span>
                <span class="min-w-0"><span class="block text-[13px] font-semibold leading-tight text-neutral-900">Event</span><span class="block text-[11px] text-neutral-500">door_opened</span></span>
              </div>
              <div class="absolute flex items-center gap-2.5 rounded-lg border border-indigo-200 bg-indigo-50/40 px-3 py-2 shadow-sm" style="left:308px;top:151px;width:180px;">
                <span class="grid h-7 w-7 shrink-0 place-items-center rounded-md bg-indigo-100 text-indigo-600"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v5l3 2 M12 21a9 9 0 1 1 0-18 9 9 0 0 1 0 18Z" /></svg></span>
                <span class="min-w-0"><span class="block text-[13px] font-semibold leading-tight text-neutral-900">Time window</span><span class="block text-[11px] text-neutral-500">09:00 – 17:00</span></span>
              </div>
              <div class="absolute flex items-center gap-2.5 rounded-lg border border-neutral-200 bg-white px-3 py-2 shadow-sm" style="left:528px;top:53px;width:156px;">
                <span class="grid h-7 w-7 shrink-0 place-items-center rounded-md bg-emerald-50 text-emerald-600"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1Z M3.5 7l8.5 6 8.5-6" /></svg></span>
                <span class="min-w-0"><span class="block text-[13px] font-semibold leading-tight text-neutral-900">Email ops</span><span class="block text-[11px] text-neutral-500">integration</span></span>
              </div>
              <div class="absolute flex items-center gap-2.5 rounded-lg border border-neutral-200 bg-white px-3 py-2 shadow-sm" style="left:528px;top:257px;width:156px;">
                <span class="grid h-7 w-7 shrink-0 place-items-center rounded-md bg-emerald-50 text-emerald-600"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7h10 M18 7h2 M4 12h2 M10 12h10 M4 17h7 M15 17h5 M14 5v4 M6 10v4 M11 15v4" /></svg></span>
                <span class="min-w-0"><span class="block text-[13px] font-semibold leading-tight text-neutral-900">Set buzzer = on</span><span class="block text-[11px] text-neutral-500">set value</span></span>
              </div>

